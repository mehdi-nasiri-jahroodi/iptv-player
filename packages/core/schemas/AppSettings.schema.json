{
  "$ref": "#/definitions/AppSettings",
  "definitions": {
    "AppSettings": {
      "type": "object",
      "properties": {
        "theme": {
          "type": "string",
          "enum": [
            "light",
            "dark",
            "system"
          ]
        },
        "playerBufferMode": {
          "type": "string",
          "enum": [
            "balanced",
            "aggressive",
            "conservative"
          ]
        },
        "autoPlay": {
          "type": "boolean",
          "default": false
        }
      },
      "required": [
        "theme",
        "playerBufferMode"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
