{
  "name": "core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "iptv-player": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "schemas": "node ./scripts/generate-schemas.mjs"
  },
  "nx": {
    "targets": {
      "schemas": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "./node_modules/.bin/nx run core:build",
            "node packages/core/scripts/generate-schemas.mjs"
          ]
        }
      }
    }
  },
  "dependencies": {
    "tslib": "^2.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "zod-to-json-schema": "^3.25.2"
  }
}
